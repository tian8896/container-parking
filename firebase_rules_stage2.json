{
  "rules": {
    // 阶段 2：完全安全规则
    // 只有登录用户可以访问，只能看到自己的数据
    
    "cpms_v2": {
      // 只有登录用户可以读取
      ".read": "auth != null",
      // 只有登录用户可以写入
      ".write": "auth != null",
      "$recordId": {
        // 读取：owner 是当前用户，或是管理员
        ".read": "auth != null && (
          data.child('owner').val() === auth.uid || 
          root.child('cpms_admins/' + auth.uid).val() === true
        )",
        // 写入：owner 是当前用户，或是管理员
        ".write": "auth != null && (
          (data.exists() && data.child('owner').val() === auth.uid) ||
          (!data.exists() && newData.child('owner').val() === auth.uid) ||
          root.child('cpms_admins/' + auth.uid).val() === true
        )",
        // 验证：新记录必须有 owner 字段
        ".validate": "newData.hasChild('owner')"
      }
    },
    
    "cpms_settings": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    
    "cpms_users": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('cpms_admins/' + auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('cpms_admins/' + auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('cpms_admins/' + auth.uid).val() === true)"
      }
    },
    
    // 管理员列表
    "cpms_admins": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('cpms_admins/' + auth.uid).val() === true"
    }
  }
}
